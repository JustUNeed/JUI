<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:controls="clr-namespace:JUI.Controls">

    <!-- ============ 标题栏按钮: 最小化 / 最大化(灰色高亮) ============ -->
    <Style x:Key="JuiCaptionButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Jui.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource Jui.Surface.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource Jui.Surface.Active}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ 标题栏按钮: 关闭(红色高亮 + 白色图标) ============ -->
    <Style x:Key="JuiCloseButtonStyle" TargetType="Button">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Jui.Text.Primary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        <Setter Property="FontSize" Value="10"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- 关闭按钮在右上角, 高亮块跟随窗口圆角(右上角) -->
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                           >
                        <ContentPresenter x:Name="Content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource Jui.Close.Hover}"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="White"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background"
                                    Value="{DynamicResource Jui.Close.Pressed}"/>
                            <Setter TargetName="Content" Property="TextElement.Foreground" Value="White"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============ JuiWindow 默认样式 ============ -->
    <Style TargetType="{x:Type controls:JuiWindow}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource Jui.Text.Primary}"/>
        <Setter Property="WindowStyle" Value="None"/>
        <Setter Property="AllowsTransparency" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JuiWindow}">
                    <!-- 外层透明留白: 给阴影 / 圆角抗锯齿留余量(可选) -->
                    <Border x:Name="LayoutRoot" Background="Transparent">
                        <!-- 真正的"窗口背景": 颜色 / 边框 / 圆角都在这里 -->
                        <Border x:Name="RootBorder"
                                Background="{DynamicResource Jui.Surface.Window}"
                                BorderBrush="{DynamicResource Jui.Border}"
                                BorderThickness="1"
                                CornerRadius="{Binding EffectiveCornerRadius, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="{TemplateBinding BorderThickness}">
                            <!-- 用同样的圆角裁剪内容, 防止内容溢出圆角 -->
                            <Border x:Name="ClipBorder"
        CornerRadius="{Binding EffectiveCornerRadius, RelativeSource={RelativeSource TemplatedParent}}"
        SnapsToDevicePixels="True">
                                <Border.OpacityMask>
                                    <!-- OpacityMask 只取 alpha 通道, 这里的颜色不会显示,
             只需"不透明"即可让圆角内区域可见。这是裁剪用的技术遮罩, 非配色。 -->
                                    <VisualBrush>
                                        <VisualBrush.Visual>
                                            <Border Background="Black"
                        CornerRadius="{Binding EffectiveCornerRadius, RelativeSource={RelativeSource TemplatedParent}}"
                        Width="{Binding ActualWidth, ElementName=ClipBorder}"
                        Height="{Binding ActualHeight, ElementName=ClipBorder}"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Border.OpacityMask>
                                <AdornerDecorator>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition x:Name="TitleRow" Height="30"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- 内容区 -->
                                        <ContentPresenter x:Name="ContentHost"
                                                      Grid.Row="1"
                                                      Content="{TemplateBinding Content}"/>

                                        <!-- 标题栏背景 + 标题文字 -->
                                        <Grid x:Name="TitleBar"
                                          Grid.Row="0"
                                          Background="{DynamicResource Jui.Surface.Default}">
                                            <TextBlock x:Name="TitleText"
                                                   Text="{TemplateBinding Title}"
                                                   Foreground="{DynamicResource Jui.Text.Primary}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Left"
                                                   Margin="12,0,0,0"
                                                   FontSize="13"/>
                                        </Grid>

                                        <!-- 三个按钮: 最上层, 贴右上角可点 -->
                                        <StackPanel x:Name="CaptionButtons"
                                                Grid.Row="0"
                                                Grid.RowSpan="2"
                                                Panel.ZIndex="100"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Top"
                                                Background="Transparent"
                                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                            <Button x:Name="PART_MinButton"
                                                Style="{StaticResource JuiCaptionButtonStyle}"
                                                ToolTip="最小化"
                                                Content="&#xE921;"/>
                                            <Button x:Name="PART_MaxButton"
                                                Style="{StaticResource JuiCaptionButtonStyle}"
                                                ToolTip="最大化"
                                                Content="&#xE922;"/>
                                            <Button x:Name="PART_CloseButton"
                                                Style="{StaticResource JuiCloseButtonStyle}"
                                                ToolTip="关闭"
                                                Content="&#xE8BB;"/>
                                        </StackPanel>
                                    </Grid>
                                </AdornerDecorator>
                            </Border>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>

                        <!-- 模式2: 无标题栏(隐藏标题栏与按钮, 边框可拖动改尺寸, 仍保留背景与圆角) -->
                        <Trigger Property="TitleBarMode" Value="NoTitleBar">
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="TitleBar" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="CaptionButtons" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TitleRow" Property="Height" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.Row" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.RowSpan" Value="2"/>
                        </Trigger>

                        <!-- 模式3: 侵入式(内容铺满, 标题栏透明, 标题文字隐藏, 按钮保留) -->
                        <Trigger Property="TitleBarMode" Value="Immersive">
                            <Setter TargetName="TitleRow" Property="Height" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.Row" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.RowSpan" Value="2"/>
                            <Setter TargetName="TitleBar" Property="Background" Value="Transparent"/>
                            <Setter TargetName="TitleBar" Property="Height" Value="30"/>
                            <Setter TargetName="TitleBar" Property="VerticalAlignment" Value="Top"/>
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>

                        <!-- 模式4: 完全无边框(无标题、无按钮、无边框、无背景, 不可拖边改尺寸) -->
                        <Trigger Property="TitleBarMode" Value="Borderless">
                            <Setter TargetName="RootBorder" Property="Background" Value="Transparent"/>
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="TitleBar" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="CaptionButtons" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="TitleRow" Property="Height" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.Row" Value="0"/>
                            <Setter TargetName="ContentHost" Property="Grid.RowSpan" Value="2"/>
                        </Trigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
