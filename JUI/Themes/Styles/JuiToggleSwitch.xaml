<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JUI.Controls">

    <Style TargetType="{x:Type controls:JuiToggleSwitch}">
        <Setter Property="Width" Value="32"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JuiToggleSwitch}">
                    <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                        <!-- 方形轨道 -->
                        <Border x:Name="Track"
                                CornerRadius="0"
                                Background="{DynamicResource Jui.Surface.Active}"
                                BorderBrush="{DynamicResource Jui.Surface.Active}"
                                BorderThickness="1"
                                SnapsToDevicePixels="True"/>
                        <!-- 方形滑块 -->
                        <Rectangle x:Name="Thumb"
                                   Width="14" Height="14"
                                   HorizontalAlignment="Left"
                                   VerticalAlignment="Center"
                                   Margin="2,0,0,0"
                                   Fill="{DynamicResource Jui.Surface.Window}"
                                   SnapsToDevicePixels="True">
                            <Rectangle.RenderTransform>
                                <TranslateTransform x:Name="ThumbTransform" X="0"/>
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track" Property="Background"
                                    Value="{DynamicResource Jui.Accent}"/>

                            <Setter TargetName="Track" Property="BorderBrush"
        Value="{DynamicResource Jui.Accent}"/>
                           
                            <Setter TargetName="Thumb" Property="Fill"
                                    Value="{DynamicResource Jui.Surface.Window}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="14" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbTransform"
                                            Storyboard.TargetProperty="X"
                                            To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
