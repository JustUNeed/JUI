<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:JUI.Controls">

    <Style TargetType="{x:Type controls:JuiImageViewer}">
        <Setter Property="Background" Value="{DynamicResource Jui.Surface.Window}"/>
        <Setter Property="ClipToBounds" Value="True"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:JuiImageViewer}">
                    <Grid x:Name="PART_Container"
                          Background="{TemplateBinding Background}"
                          ClipToBounds="True">
                        <Image x:Name="PART_Image"
                               RenderTransformOrigin="0,0"
                               Stretch="Uniform"
                               SnapsToDevicePixels="True"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
