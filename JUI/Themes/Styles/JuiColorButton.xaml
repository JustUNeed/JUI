<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:JUI.Controls">

    <!-- 色块按钮 -->
    <Style TargetType="{x:Type c:JuiColorButton}">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="24"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:JuiColorButton}">
                    <Border x:Name="Bd"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            BorderBrush="{DynamicResource Jui.Border}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            SnapsToDevicePixels="True">
                        <!-- 用当前选中色作为背景 -->
                        <Border.Background>
                            <SolidColorBrush Color="{Binding SelectedColor,
                                RelativeSource={RelativeSource TemplatedParent}}"/>
                        </Border.Background>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{DynamicResource Jui.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- HSV 取色面板 -->
    <Style TargetType="{x:Type c:ColorPickerPanel}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type c:ColorPickerPanel}">
                    <Border Background="{DynamicResource Jui.Surface.Default}"
                            BorderBrush="{DynamicResource Jui.Border}"
                            BorderThickness="1" CornerRadius="6" Padding="10">
                        <StackPanel>
                            <!-- SV 区 + 色相条 -->
                            <Grid Height="180">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="18"/>
                                </Grid.ColumnDefinitions>

                                <!-- 饱和度-明度方形区 -->
                                <Border x:Name="PART_SVPanel" Grid.Column="0"
                                        CornerRadius="4" ClipToBounds="True">
                                    <Grid>
                                        <!-- 横向: 白 -> 纯色相 -->
                                        <Rectangle x:Name="PART_SVColorLayer">
                                            <Rectangle.Fill>
                                                <SolidColorBrush Color="Red"/>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="#FFFFFFFF"/>
                                                    <GradientStop Offset="1" Color="#00FFFFFF"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <!-- 纵向: 透明 -> 黑 -->
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Offset="0" Color="#00000000"/>
                                                    <GradientStop Offset="1" Color="#FF000000"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Canvas x:Name="PART_SVCanvas" IsHitTestVisible="False">
                                            <Ellipse x:Name="PART_SVCursor" Width="12" Height="12"
                                                     Stroke="White" StrokeThickness="2"
                                                     IsHitTestVisible="False">
                                                <Ellipse.Effect>
                                                    <DropShadowEffect ShadowDepth="0"
                                                        BlurRadius="2" Color="Black" Opacity="0.6"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                        </Canvas>
                                    </Grid>
                                </Border>

                                <!-- 色相竖条 -->
                                <Border x:Name="PART_HueBar" Grid.Column="2"
                                        CornerRadius="3" ClipToBounds="True">
                                    <Grid>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Offset="0.00" Color="#FF0000"/>
                                                    <GradientStop Offset="0.17" Color="#FFFF00"/>
                                                    <GradientStop Offset="0.33" Color="#00FF00"/>
                                                    <GradientStop Offset="0.50" Color="#00FFFF"/>
                                                    <GradientStop Offset="0.67" Color="#0000FF"/>
                                                    <GradientStop Offset="0.83" Color="#FF00FF"/>
                                                    <GradientStop Offset="1.00" Color="#FF0000"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Canvas x:Name="PART_HueCanvas" IsHitTestVisible="False">
                                            <Rectangle x:Name="PART_HueCursor"
                                                       Width="18" Height="4"
                                                       Stroke="White" StrokeThickness="1.5"
                                                       Fill="#80FFFFFF" IsHitTestVisible="False"/>
                                        </Canvas>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- 预览 + Hex 输入 -->
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="28"/>
                                    <ColumnDefinition Width="4"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="PART_oldColor" Grid.Column="0"
               CornerRadius="0" Height="28" 
               BorderBrush="{DynamicResource Jui.Border}"
               />
                                <Border x:Name="PART_Preview" Grid.Column="2"
                                        CornerRadius="0" Height="28"
                                        BorderBrush="{DynamicResource Jui.Border}"
                                        BorderThickness="0"/>
                                <c:JuiTextBox x:Name="PART_HexBox" Grid.Column="4"
                                         VerticalContentAlignment="Center"
                                         Background="{DynamicResource Jui.Surface.Window}"
                                         Foreground="{DynamicResource Jui.Text.Primary}"
                                         Padding="6,0"/>
                            </Grid>

                            <!-- 确定 / 取消 -->
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Right" Margin="0,10,0,0">
                                <c:JuiButton  Content="取消"
                                             Width="60" Margin="0,0,8,0"/>
                                <c:JuiButton x:Name="PART_OK" Content="确定" Width="60"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
