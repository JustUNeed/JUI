<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Jui.Background"        Color="#1E1E1E"/>
    <SolidColorBrush x:Key="Jui.Surface"           Color="#2A2A2A"/>
    <SolidColorBrush x:Key="Jui.Foreground"        Color="#F0F0F0"/>
    <SolidColorBrush x:Key="Jui.ForegroundMuted"   Color="#A0A0A0"/>
    <SolidColorBrush x:Key="Jui.Border"            Color="#3F3F3F"/>
    <SolidColorBrush x:Key="Jui.Accent"            Color="#2A9FFF"/>
    <SolidColorBrush x:Key="Jui.AccentForeground"  Color="#FFFFFF"/>

</ResourceDictionary>
