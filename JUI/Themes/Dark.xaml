<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- 表面 / 背景:窗口 → 默认 → 悬停 → 激活(沉 → 浮) -->
    <SolidColorBrush x:Key="Jui.Surface.Window"  Color="#1A1A1A"/>
    <SolidColorBrush x:Key="Jui.Surface.Default" Color="#242424"/>
    <SolidColorBrush x:Key="Jui.Surface.Hover"   Color="#2E2E2E"/>
    <SolidColorBrush x:Key="Jui.Surface.Active"  Color="#383838"/>

    <!-- 文字:主 → 次 → 禁用 -->
    <SolidColorBrush x:Key="Jui.Text.Primary"    Color="#F0F0F0"/>
    <SolidColorBrush x:Key="Jui.Text.Secondary"  Color="#A0A0A0"/>
    <SolidColorBrush x:Key="Jui.Text.Disabled"   Color="#5A5A5A"/>

    <!-- 强调:默认 + 悬停(同色系深浅) -->
    <SolidColorBrush x:Key="Jui.Accent"          Color="#FFFFFF"/>
    <SolidColorBrush x:Key="Jui.Accent.Hover"    Color="#888888"/>


    <!-- 强调色上的反白文字 -->
    <SolidColorBrush x:Key="Jui.Text.OnAccent" Color="#FFFFFF"/>
    
    <!-- 边框 / 分隔 -->
    <SolidColorBrush x:Key="Jui.Border"          Color="#3A3A3A"/>

    <!-- 关闭按钮专用红色 -->
    <SolidColorBrush x:Key="Jui.Close.Hover"     Color="#E81123"/>
    <SolidColorBrush x:Key="Jui.Close.Pressed"   Color="#C50F1F"/>

</ResourceDictionary>
