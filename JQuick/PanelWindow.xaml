<jui:JuiWindow x:Class="JQuick.PanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JQuick"
        xmlns:jui="clr-namespace:JUI.Controls;assembly=JUI"
        Title="图片剪贴板"
        Width="400" Height="500"
        TitleBarMode="NoTitleBar"
        ShowInTaskbar="False"
        AllowDrop="True">
    <jui:JuiWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </jui:JuiWindow.Resources>

    <DockPanel x:Name="PanelRoot" Margin="8">
        <StackPanel DockPanel.Dock="Top"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Margin="0,0,0,6">
            <ToggleButton x:Name="PinToggle"
                  Content="常驻模式"
                  Margin="0,0,6,0"
                  Checked="PinToggle_Changed"
                  Unchecked="PinToggle_Changed"/>
            <Button x:Name="SettingsButton"
            Content="设置"
            Padding="8,2"
            Click="SettingsButton_Click"/>
        </StackPanel>
        <!-- 图片剪贴板 -->
        <local:ImageClipboardControl x:Name="ClipboardGrid"
                                     DockPanel.Dock="Top"
                                     ItemWidth="80" ItemHeight="80"
                                     ItemSpacing="2" MaxRows="3"
                                     ItemCornerRadius="4">
            <local:ImageClipboardControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot">
                        <!-- 占位背景, 始终在底层 -->
                        <Border Background="#1A000000" CornerRadius="6"/>

                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>

                        <!-- 下载中提示: 仅 IsLoading 时显示 -->
                        <TextBlock Text="…" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                        <Button x:Name="PART_DeleteButton" Content="✕" Width="18" Height="18"
                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>

            </local:ImageClipboardControl.ItemTemplate>
        </local:ImageClipboardControl>

        <!-- 快捷方式启动器 -->
        <local:AppLauncherControl x:Name="Launcher"
                                    DockPanel.Dock="Top"
                                  ItemWidth="80" ItemHeight="90"
                                  ItemSpacing="2" ItemCornerRadius="4">
            <local:AppLauncherControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <!-- 图标区: 占满上方并居中 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 文本: 靠下 -->
                        </Grid.RowDefinitions>

                        <!-- 图标: 在上方区域水平垂直居中 -->
                        <Grid Grid.Row="0" Width="48" Height="48"
                  HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Background="#1A000000" CornerRadius="4"/>
                            <!-- 占位 -->
                            <Image Source="{Binding Icon}"/>
                            <!-- 加载完才显示 -->
                        </Grid>

                        <!-- 名称: 一行, 靠下居中, 超出省略号 -->
                        <TextBlock Grid.Row="1" Text="{Binding DisplayName}"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="2,2,2,4"
                       Foreground="{DynamicResource Jui.Text.Primary}"/>

                        <!-- 删除按钮: 右上角, 悬停显示 -->
                        <Button x:Name="PART_DeleteButton" Grid.Row="0" Content="✕"
                    Width="18" Height="18"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </local:AppLauncherControl.ItemTemplate>

        </local:AppLauncherControl>

        <local:FolderBoxControl x:Name="FolderBox"
                                  DockPanel.Dock="Top"
                        ItemWidth="120" ItemHeight="40"
                        ItemSpacing="2" ItemCornerRadius="8">
            <local:FolderBoxControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                        <Border Background="Black">

                            <TextBlock Text="{Binding DisplayName}" TextAlignment="Center" Margin="8" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Jui.Text.Primary}"/>

                        </Border>

                        <Button Content="✕" Width="18" Height="18"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="2" Click="RemoveFolder_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver,
                                             RelativeSource={RelativeSource AncestorType=Grid}}"
                                             Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </local:FolderBoxControl.ItemTemplate>
        </local:FolderBoxControl>

        <local:TextClipboardControl x:Name="TextClip"
                            DockPanel.Dock="Top"
                            ItemHeight="36" ItemSpacing="3"
                            ItemCornerRadius="6"
                            MaxVisibleItems="6">
            <local:TextClipboardControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                        <Border Background="#1A000000" CornerRadius="6"/>

                        <TextBlock Text="{Binding Preview}"
                           VerticalAlignment="Center"
                           Margin="10,0,28,0"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{DynamicResource Jui.Text.Primary}"/>

                        <Button x:Name="PART_DeleteButton" Content="✕"
                        Width="18" Height="18"
                        HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </local:TextClipboardControl.ItemTemplate>
        </local:TextClipboardControl>

    </DockPanel>
</jui:JuiWindow>
