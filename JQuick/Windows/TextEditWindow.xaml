<jui:JuiWindow x:Class="JQuick.TextEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:jui="clr-namespace:JUI.Controls;assembly=JUI"
        Title="编辑文本"
        Width="420" Height="320"
        TitleBarMode="Normal"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">
        <!-- 底部按钮行 -->
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button Content="保存并关闭"
                    Padding="12,4"
                    Click="Save_Click"/>
        </StackPanel>

        <!-- 多行编辑区 -->
        <TextBox x:Name="Editor"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 VerticalContentAlignment="Top"
                 Background="{DynamicResource Jui.Surface.Window}"
                 Foreground="{DynamicResource Jui.Text.Primary}"
                 BorderBrush="{DynamicResource Jui.Border}"
                 Padding="8"/>
    </DockPanel>
</jui:JuiWindow>
