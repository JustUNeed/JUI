<jui:JuiWindow x:Class="JQuick.PanelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:JQuick"
        xmlns:jui="clr-namespace:JUI.Controls;assembly=JUI"
        Title="图片剪贴板"
        Width="300" 
              
        TitleBarMode="NoTitleBar"
        ShowInTaskbar="False"
              Topmost="True"
        AllowDrop="True">
    <jui:JuiWindow.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </jui:JuiWindow.Resources>

    <DockPanel x:Name="PanelRoot" Margin="4">
        <!-- 顶部工具行: 常驻态下作为拖动手柄 -->
        <Border x:Name="DragBar"
                DockPanel.Dock="Top"
                Background="Transparent"
               
                MouseLeftButtonDown="DragBar_MouseLeftButtonDown"
                MouseMove="DragBar_MouseMove"
                MouseLeftButtonUp="DragBar_MouseLeftButtonUp">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">


                <jui:JuiIconToggleButton x:Name="PinToggle"
                            
                            
                              Checked="PinToggle_Changed"
                              Unchecked="PinToggle_Changed">
                    <Path Stretch="Uniform" Width="12" Height="12"
Fill="{Binding Path=(TextElement.Foreground), RelativeSource={RelativeSource AncestorType=Control}}"
Data="M235.32,81.37 174.63,20.69 a16,16,0,0,0-22.63,0 L98.37,74.49 c-10.66-3.34-35-7.37-60.4,13.14 a16,16,0,0,0-1.29,23.78 L85,159.71 42.34,202.34 a8,8,0,0,0,11.32,11.32 L96.29,171 l48.29,48.29 A16,16,0,0,0,155.9,224 c.38,0,.75,0,1.13,0 a15.93,15.93,0,0,0,11.64-6.33 c19.64-26.1,17.75-47.32,13.19-60 L235.33,104 A16,16,0,0,0,235.32,81.37 Z M224,92.69 h0 l-57.27,57.46 a8,8,0,0,0-1.49,9.22 c9.46,18.93-1.8,38.59-9.34,48.62 L48,100.08 c12.08-9.74,23.64-12.31,32.48-12.31 A40.13,40.13,0,0,1,96.81,91 a8,8,0,0,0,9.25-1.51 L163.32,32 224,92.68 Z"/>

                </jui:JuiIconToggleButton>


            </StackPanel>
        </Border>

        <!--快捷文件夹 -->
        <local:FolderBoxControl x:Name="FolderBox" Background="{DynamicResource Jui.Surface.Default}" 
                                  DockPanel.Dock="Top"
                        ItemWidth="110" ItemHeight="40"
                         EmptyContent="暂无文件夹，将文件夹拖入此处"
                        ItemSpacing="2" ItemCornerRadius="8">

            <local:FolderBoxControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                        <Border Background="{DynamicResource Jui.Surface.Hover}" >

                            <TextBlock Text="{Binding DisplayName}" TextAlignment="Center" Margin="8" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Jui.Text.Primary}"/>

                        </Border>

                        <jui:JuiDeleteBadge Visibility="Hidden" x:Name="PART_DeleteButton"/>

                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_DeleteButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </local:FolderBoxControl.ItemTemplate>
        </local:FolderBoxControl>




        
        <!-- 图片剪贴板 -->
        <local:ImageClipboardControl x:Name="ClipboardGrid" Background="{DynamicResource Jui.Surface.Default}" Margin="0,4,0,0"
                                     DockPanel.Dock="Top"
                                     ItemWidth="70" ItemHeight="70"
                                     ItemSpacing="2" MaxRows="3"
                                      EmptyContent="暂无图片，粘贴图片或拖入此处" 
                                     ItemCornerRadius="4">
        
            <local:ImageClipboardControl.ItemTemplate>
                <DataTemplate>
        
                    
                    <Grid x:Name="ItemRoot">
                        
                        <!-- 占位背景, 始终在底层 -->
                        <Border Background="#1A000000" CornerRadius="6"/>

                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>

                        <!-- 下载中提示: 仅 IsLoading 时显示 -->
                        <TextBlock Text="…" Foreground="White"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

                        <jui:JuiDeleteBadge Visibility="Hidden" x:Name="PART_DeleteButton"/>
                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_DeleteButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>

            </local:ImageClipboardControl.ItemTemplate>
        </local:ImageClipboardControl>

        <!-- 快捷方式启动器 -->
        <local:AppLauncherControl x:Name="Launcher" Background="{DynamicResource Jui.Surface.Default}" Margin="0,4,0,0"
                                    DockPanel.Dock="Top"
                                  ItemWidth="70" ItemHeight="70"
                                    EmptyContent="暂无快捷方式，请将文件拖入此处"
                                  ItemSpacing="2" ItemCornerRadius="4">
     
            
                    
            <local:AppLauncherControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <!-- 图标区: 占满上方并居中 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 文本: 靠下 -->
                        </Grid.RowDefinitions>

                        <!-- 图标: 在上方区域水平垂直居中 -->
                       
                          
                            <!-- 占位 -->
                            <Image Source="{Binding Icon}" Grid.Row="0" Width="40" Height="40"  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <!-- 加载完才显示 -->
                      

                        <!-- 名称: 一行, 靠下居中, 超出省略号 -->
                        <TextBlock Grid.Row="1" Text="{Binding DisplayName}" FontSize="10" FontFamily="Microsoft Baiti"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Margin="2,2,2,4"
                       Foreground="{DynamicResource Jui.Text.Secondary}"/>

                 


                        <jui:JuiDeleteBadge x:Name="PART_DeleteButton" Grid.Row="0"
                    Visibility="Hidden"
                    />


                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_DeleteButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </local:AppLauncherControl.ItemTemplate>

        </local:AppLauncherControl>


        
        
        
        <local:TextClipboardControl x:Name="TextClip" Background="{DynamicResource Jui.Surface.Default}" Margin="0,4,0,0"
                            DockPanel.Dock="Top"
                            ItemHeight="36" ItemSpacing="2"
                            ItemCornerRadius="2"
                                     EmptyContent="暂无文本项，粘贴文本或拖入此处"
                            MaxVisibleItems="6">
            <local:TextClipboardControl.ItemTemplate>




                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                     

                        <TextBlock Text="{Binding Preview}"
                   VerticalAlignment="Center"
                   Margin="10,0,10,0"
                   TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource Jui.Text.Secondary}"
                                   ToolTip="{Binding Preview}"/>

                        <!-- 右侧操作按钮: 编辑 + 删除, 悬浮才显示 -->
                        <DockPanel Grid.Row="0" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,0,0">
                            <jui:JuiDeleteBadge x:Name="PART_EditButton"
                                Visibility="Hidden"
                                Glyph="&#xE70F;"
                                ToolTip="编辑"/>
                            <jui:JuiDeleteBadge x:Name="PART_DeleteButton"
                                Visibility="Hidden"/>
                        </DockPanel>
                    </Grid>
                    <DataTemplate.Triggers>
                        <Trigger SourceName="ItemRoot" Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_EditButton" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="PART_DeleteButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </DataTemplate.Triggers>
                </DataTemplate>

            </local:TextClipboardControl.ItemTemplate>
        </local:TextClipboardControl>


        <TextBlock Text=""
        DockPanel.Dock="Bottom"
      HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis"
      Foreground="{DynamicResource Jui.Text.Primary}"/>

    </DockPanel>
</jui:JuiWindow>
