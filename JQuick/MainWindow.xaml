<Window x:Class="JQuick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JQuick"
        xmlns:jui="clr-namespace:JUI.Controls;assembly=JUI"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
         Background="{DynamicResource Jui.Background}">

    <jui:JuiGrid x:Name="Grid" AllowDropOnItem = "true"  ItemWidth="80" ItemHeight="80" MaxRows="3" Background="Black" >
        <jui:JuiGrid.ItemTemplate>
            <DataTemplate>
                <Grid x:Name="ItemRoot"    Width="{Binding ItemWidth, RelativeSource={RelativeSource AncestorType=jui:JuiGrid}}"
      Height="{Binding ItemHeight, RelativeSource={RelativeSource AncestorType=jui:JuiGrid}}">
                  
                    <Border Background="Blue" CornerRadius="0">
                        <StackPanel>
                            <Image Source="{Binding Thumbnail}"  Stretch="UniformToFill"/>
                      
                        </StackPanel>
                    </Border>

                    <!-- 叉叉: 自己绑定父 Grid 的 IsMouseOver 决定显隐 -->
                    <Button Content="✕" Width="20" Height="20"
            HorizontalAlignment="Right" VerticalAlignment="Top"
            Margin="0"
            Click="DeleteBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Visibility" Value="Hidden"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver,
                                 RelativeSource={RelativeSource AncestorType=Grid}}"
                                 Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>

            </DataTemplate>
        </jui:JuiGrid.ItemTemplate>

    </jui:JuiGrid>


</Window>
