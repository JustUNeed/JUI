<Window x:Class="JQuick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JQuick"
        xmlns:jui="clr-namespace:JUI.Controls;assembly=JUI"
        mc:Ignorable="d"
        Title="图片剪贴板" Height="500" Width="400"
       >

    <DockPanel Margin="8">
        <!-- 图片剪贴板 -->
        <local:ImageClipboardControl x:Name="ClipboardGrid"
                                     DockPanel.Dock="Top"
                                     ItemWidth="80" ItemHeight="80"
                                     ItemSpacing="6" MaxRows="3"
                                     ItemCornerRadius="8">
            <local:ImageClipboardControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot">
                        <!-- 占位背景,始终在底层 -->
                        <Border Background="#1A000000" CornerRadius="6"/>
                        
                        <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"/>

                        <Button x:Name="PART_DeleteButton" Content="✕" Width="18" Height="18"
        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                    </Grid>

                </DataTemplate>
            </local:ImageClipboardControl.ItemTemplate>
        </local:ImageClipboardControl>

        <!-- 快捷方式启动器 -->
        <local:AppLauncherControl x:Name="Launcher"
                                  ItemWidth="80" ItemHeight="90"
                                  ItemSpacing="6" ItemCornerRadius="8">
            <local:AppLauncherControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <Grid Width="48" Height="48">
                            <Border Background="#1A000000" CornerRadius="4"/>
                            <!-- 占位 -->
                            <Image Source="{Binding Icon}"/>
                            <!-- 加载完才显示 -->
                        </Grid>
                        <TextBlock Text="{Binding DisplayName}" TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{DynamicResource Jui.Text.Primary}"/>
                    </StackPanel>
                </DataTemplate>
            </local:AppLauncherControl.ItemTemplate>
        </local:AppLauncherControl>

        <local:FolderBoxControl x:Name="FolderBox"
                        ItemWidth="100" ItemHeight="100"
                        ItemSpacing="6" ItemCornerRadius="8">
            <local:FolderBoxControl.ItemTemplate>
                <DataTemplate>
                    <Grid x:Name="ItemRoot" Background="Transparent">
                        <StackPanel VerticalAlignment="Center">
                    
                            <TextBlock Text="{Binding DisplayName}" TextAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               Foreground="{DynamicResource Jui.Text.Primary}"/>
                         
                        </StackPanel>

                        <Button Content="✕" Width="18" Height="18"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="2" Click="RemoveFolder_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Hidden"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMouseOver,
                                             RelativeSource={RelativeSource AncestorType=Grid}}"
                                             Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </DataTemplate>
            </local:FolderBoxControl.ItemTemplate>
        </local:FolderBoxControl>

    </DockPanel>
</Window>